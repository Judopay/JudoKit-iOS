default_platform(:ios)

compilation_database_path = ENV["XCODE_COMPILATION_DB_PATH"] || "build/compilation_database"
@sample_apps_dir = "#{File.expand_path('..')}/Examples"
@sample_apps = [
  {
    app_identifier: 'com.judo.JudoPayDemoObjC',
    app_identifier_staging: 'com.judo.JudoPayDemoObjC.staging',
    app_identifier_ui_tests: 'com.judo.JudoPayDemoObjC.ObjectiveCExampleAppUITests.*',
    firebase_app_id: '1:34238832242:ios:d7db21b04007e9ee63eceb',
    firebase_app_id_staging: '1:34238832242:ios:62eb2547e6cd6a2663eceb',
    flavor: 'obj-c',
    instrumented_tests: true,
    scheme: 'ObjectiveCExampleApp',
  },
  {
    app_identifier: 'com.judo.JudoPayDemoSwift',
    app_identifier_ui_tests: 'com.judo.JudoPayDemoSwift.SwiftExampleAppUITests.*',
    firebase_app_id: '1:34238832242:ios:7bbdd8e61adb48e863eceb',
    flavor: 'swift',
    instrumented_tests: true,
    scheme: 'SwiftExampleAppUITests',
  },
  {
    app_identifier: 'com.judo.JudoPayDemoCarthage',
    firebase_app_id: '1:34238832242:ios:eafceec3517c076463eceb',
    flavor: 'carthage',
    scheme: 'CarthageExampleApp',
  },
  {
    app_identifier: 'com.judopay.SPMExampleApp',
    firebase_app_id: '1:34238832242:ios:f07ce32928073fa463eceb',
    flavor: 'spm',
    scheme: 'SPMExampleApp',
  }
]

platform :ios do
  before_all do
    setup_ci

    Dir.chdir('..') do
      FileUtils.mkdir_p(compilation_database_path)
    end

    if [
      'build',
      'package_instrumented_tests',
      'build_sample_apps',
      'build_sample_app'
    ].include?(lane_context[SharedValues::LANE_NAME])
      app_store_connect_api_key
    end
  end

  desc "Lint SDK"
  lane :lint do
    Dir.chdir('..') do
      sh('./scripts/judo_kit_lint.sh')
    end
  end

  desc "Build SDK, Sample apps and package instrumented tests"
  lane :build do
    build_sdk
    build_sample_apps
    package_instrumented_tests
  end

  desc "Run SDK tests and sample app instrumented tests"
  lane :test do
    test_sdk
    run_instrumented_tests
  end

  desc "Build SDK"
  lane :build_sdk do
    build_app(
      skip_codesigning: true,
      skip_package_ipa: true,
      skip_package_dependencies_resolution: true,
      scheme: 'JudoKit_iOS',
      project: './JudoKit_iOS.xcodeproj',
      xcargs: "OTHER_CFLAGS='$(inherited) -gen-cdb-fragment-path #{compilation_database_path}'"
    )
  end

  desc "Run SDK tests"
  lane :test_sdk do
    run_tests(ensure_devices_found: true)
  end

  desc "Package instrumented tests for uploading to firebase"
  lane :package_instrumented_tests do
    @sample_apps.select{ |app| app[:instrumented_tests] }.each do |app|
      Dir.chdir('..') do
        FileUtils.mkdir_p(ENV['FL_OUTPUT_DIR'])
        Dir.chdir("#{ENV['DERIVED_DATA_PATH']}/Build/Products") do
          sh("zip -r ../../../#{ENV['FL_OUTPUT_DIR']}/#{app[:scheme]}.zip Debug-iphoneos #{app[:scheme]}_*.xctestrun")
        end
      end
    end
  end

  desc "Run instrumented tests on simulators"
  lane :run_instrumented_tests do
    @sample_apps.select{ |app| app[:instrumented_tests] }.each do |app|
      run_tests({
        build_for_testing: true,
        workspace: app_workspace(app[:scheme]),
        scheme: app[:scheme],
        destination: "generic/platform=iOS",
        sdk: "iphoneos",
        xcodebuild_command: "env NSUnbufferedIO=YES xcodebuild -allowProvisioningUpdates TEST_API_JUDO_ID=$JUDO_API_ID TEST_API_TOKEN=$JUDO_API_TOKEN TEST_API_SECRET=$JUDO_API_SECRET RSA_PUBLIC_KEY=$RSA_PUBLIC_KEY RAVELIN_MOCK_SERVER_URL=$RAVELIN_MOCK_SERVER_URL",
        include_simulator_logs: false
      })
    end
  end

  desc "Build Sample Apps"
  lane :build_sample_apps do
    @sample_apps.each do |app|
      build_sample_app({flavor: app[:flavor]})
    end

    @sample_apps.select{ |app| app[:app_identifier_staging] }.each do |app|
      distribute_sample_app({flavor: app[:flavor], staging: true})
    end
  end

  desc "Build specified sample app"
  lane :build_sample_app do |options|
    app = get_app(options[:flavor])

    UI.message("Running cocoapods for #{app_podfile(app[:scheme])}")
    cocoapods(podfile: app_podfile(app[:scheme])) if File.file?(app_podfile(app[:scheme]))

    inject_staging_environment(app) if options.key?(:staging) && options[:staging] == true
    app_identifier = options.key?(:staging) && options[:staging] == true ? app[:app_identifier_staging] : app[:app_identifier]
    firebase_app_id = options.key?(:staging) && options[:staging] == true ? app[:firebase_app_id_staging] : app[:firebase_app_id]

    sync_code_signing({
      type: "adhoc",
      app_identifier: app[:app_identifier_ui_tests] ? [app_identifier, app[:app_identifier_ui_tests]] : app_identifier,
    })

    latest_release = firebase_app_distribution_get_latest_release(app: firebase_app_id)
    current_version = latest_release.nil? ? 0 : latest_release[:buildVersion].to_i
    
    increment_build_number({
      xcodeproj: app_project(app[:scheme]),
      build_number:  current_version + 1
    })

    build_app({
      export_method: 'ad-hoc',
      output_name: "#{app[:scheme]}.ipa",
      project: app_project(app[:scheme]),
      scheme: app[:scheme],
      skip_archive: true,
      workspace: File.directory?(app_workspace(app[:scheme])) ? app_workspace(app[:scheme]) : nil,
      xcargs: "OTHER_CFLAGS='$(inherited) -gen-cdb-fragment-path #{compilation_database_path}'"
    })

    revert_staging_environment(app) if options.key?(:staging) && options[:staging] == true
  end

  desc "Distribute sample apps to Firebase"
  lane :distribute_sample_apps do
    @sample_apps.each do |app|
      distribute_sample_app({flavor: app[:flavor]})
    end

    @sample_apps.select{ |app| app[:app_identifier_staging] }.each do |app|
      distribute_sample_app({flavor: app[:flavor], staging: true})
    end
  end

  desc "Distribute specified sample app to Firebase"
  lane :distribute_sample_app do |options|
    app = get_app(options[:flavor])

    firebase_app_distribution({
      groups: 'default-testers',
      release_notes: changelog_from_git_commits(commits_count: 1),
      app: options[:staging] == true ? app[:firebase_app_id_staging] : app[:firebase_app_id],
    })
  end

  desc "Run full PR check pipeline"
  lane :pr_check do
    lint
    build
    test
  end
end

def app_workspace(app_scheme)
  return "#{@sample_apps_dir}/#{app_scheme}/#{app_scheme}.xcworkspace"
end

def app_project(app_scheme)
  return "#{@sample_apps_dir}/#{app_scheme}/#{app_scheme}.xcodeproj"
end

def app_plist(app_scheme)
  return "#{@sample_apps_dir}/#{app_scheme}/#{app_scheme}/Info.plist"
end

def app_podfile(app_scheme)
  return "#{@sample_apps_dir}/#{app_scheme}/Podfile"
end

def get_app(app_flavor)
  app = @sample_apps.find { |a| a[:flavor] == app_flavor }
  
  unless app
    UI.user_error!("No sample app found for flavor: #{app_flavor}")
  end
  
  return app
end

# Check if an environment variable exists and is not empty
def env_var_valid?(var_name)
  return ENV.has_key?(var_name) && !ENV[var_name].to_s.empty?
end

def replace(file_path, old_string, new_string)
  # Check if the file exists
  unless File.file?(file_path)
    UI.user_error!("File not found: #{file_path}")
  end

  # Replace the string
  new_content = File.read(file_path).gsub(old_string, new_string)

  # Write the updated content back to the file
  File.open(file_path, "w") { |file| file.puts new_content }

  UI.success("Replaced '#{old_string}' with '#{new_string}' in #{file_path}")
end

def inject_staging_environment(app)
  unless env_var_valid?('STAGING_HOST_NAME')
    UI.abort_with_message!("STAGING_HOST_NAME environment variable is not set. Unable to continue.")
  end

  Dir.chdir('..') do
    current_bundle_id = get_product_bundle_id(
      project_filepath: app_project(app[:scheme]),
      scheme: app[:scheme]
    )

    if current_bundle_id == app[:app_identifier_staging]
      UI.message("The current bundle id already matches '#{app[:app_identifier_staging]}'. No changes made.")
    else
      update_app_identifier(
        xcodeproj: app_project(app[:scheme]),
        plist_path: app_plist(app[:scheme]),
        app_identifier: app[:app_identifier_staging],
      )

      UI.message("Updated bundle ID to: #{app[:app_identifier_staging]}")

      profile_specifier = "match AdHoc"
      replace(
        "#{app_project(app[:scheme])}/project.pbxproj",
        "#{profile_specifier} #{app[:app_identifier]}",
        "#{profile_specifier} #{app[:app_identifier_staging]}"
      )
      replace("#{Dir.pwd}/Source/Models/Constants/JPConstants.h", ".judopay.com", ".#{ENV['STAGING_HOST_NAME']}")
    end
  end
end

def revert_staging_environment(app)
  files_list.append("Source/Models/Constants/JPConstants.h")
  files_list.append("#{app_project(app[:scheme])}/project.pbxproj")

  reset_git_repo(
    force: true,
    files: files_list
  )
end
